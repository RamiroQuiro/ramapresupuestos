---
import "../../styles/global.css";
import { Main } from "../ui/atomos/Main";
import BottomNav from "./BottomNav.astro";

interface Props {
  title?: string;
}

const { title = "ramaPresupuesto" } = Astro.props;
---

<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1a1a1f" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Sora:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-primary-background text-primary-textoTitle">
    <Main className="flex min-h-screen flex-col pb-20">
      <slot />
    </Main>
    <BottomNav />
  </body>
</html>
