---
const currentPath = Astro.url.pathname;

const items = [
  {
    label: "Nuevo",
    href: "/start",
    icon: "plus-circle",
    match: ["/start"],
  },
  {
    label: "Historial",
    href: "/historial",
    icon: "clock",
    match: ["/historial"],
  },
  {
    label: "Catálogo",
    href: "/catalogo",
    icon: "package",
    match: ["/catalogo"],
  },
  {
    label: "Config",
    href: "/config",
    icon: "settings",
    match: ["/config"],
  },
];

function isActive(href: string, match: string[]) {
  return match.some((m) => currentPath.startsWith(m)) || currentPath === href;
}
---

<nav
  class="fixed bottom-0 z-50 w-full border-t border-primary-border bg-primary-background/90 backdrop-blur-md safe-area-bottom"
>
  <div class="mx-auto flex max-w-lg items-center justify-around py-2">
    {items.map((item) => (
      <a
        href={item.href}
        class:list={[
          "flex flex-col items-center gap-1 px-3 py-1 text-xs transition-colors",
          isActive(item.href, item.match)
            ? "text-primary-100"
            : "text-primary-texto hover:text-primary-100",
        ]}
      >
        {item.icon === "plus-circle" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="16" />
            <line x1="8" y1="12" x2="16" y2="12" />
          </svg>
        )}
        {item.icon === "clock" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        )}
        {item.icon === "package" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16.5 9.4 7.55 4.24" />
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
            <line x1="12" y1="22.08" x2="12" y2="12" />
          </svg>
        )}
        {item.icon === "settings" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
        )}
        <span class:list={[
          "font-medium",
          isActive(item.href, item.match) ? "text-primary-100" : "",
        ]}>
          {item.label}
        </span>
      </a>
    ))}
  </div>
</nav>

<style>
  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
</style>
